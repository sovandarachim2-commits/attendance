# =============================================================================
# SalesTrack — single environment file (backend + frontend)
# Copy to .env in this folder:  copy .env.example .env
# =============================================================================

APP_NAME="SalesTrack"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://127.0.0.1:8000
APP_TIMEZONE=Asia/Phnom_Penh

# Default users created on migrate
SUPER_ADMIN_EMAIL=superadmin@shadow.com
SUPER_ADMIN_PASSWORD=SuperAdmin@123
SUPER_ADMIN_NAME="Super Admin"
SUPER_ADMIN_EMPLOYEE_CODE=SUPER-0001
ADMIN_EMAIL=admin@shadow.com
ADMIN_PASSWORD=Admin@123
ADMIN_NAME="Admin User"
ADMIN_EMPLOYEE_CODE=ADMIN-0001

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# -----------------------------------------------------------------------------
# Database (XAMPP MySQL)
# -----------------------------------------------------------------------------
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=attendance_sales_app
DB_USERNAME=root
DB_PASSWORD=

# -----------------------------------------------------------------------------
# Session / API auth (Sanctum)
# Add your PC LAN IP for phone access, e.g. 192.168.1.10,192.168.1.10:5174
# -----------------------------------------------------------------------------
SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

SANCTUM_STATEFUL_DOMAINS=localhost,localhost:5174,127.0.0.1,127.0.0.1:5174,127.0.0.1:8000

BROADCAST_CONNECTION=log
QUEUE_CONNECTION=sync
CACHE_STORE=file

# -----------------------------------------------------------------------------
# File storage
# -----------------------------------------------------------------------------
FILESYSTEM_DISK=local
ATTENDANCE_IMAGE_DISK=public

# -----------------------------------------------------------------------------
# Attendance
# -----------------------------------------------------------------------------
ATTENDANCE_OFFICE_START_TIME=08:30:00
ATTENDANCE_MISSING_CHECKOUT_ALERT_TIME=18:30:00
ATTENDANCE_DEFAULT_RADIUS_METERS=100
FACE_VERIFICATION_ENABLED=false
VITE_FACE_VERIFICATION_ENABLED=false
ATTENDANCE_VALIDATE_OFFICE_GPS=false

# -----------------------------------------------------------------------------
# Telegram / Email
# -----------------------------------------------------------------------------
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hr@salestrack.local"
MAIL_FROM_NAME="${APP_NAME}"

# -----------------------------------------------------------------------------
# Cloudflare R2 (production)
# -----------------------------------------------------------------------------
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_DEFAULT_REGION=auto
R2_BUCKET=
R2_ENDPOINT=
R2_PUBLIC_URL=
R2_USE_PATH_STYLE_ENDPOINT=false

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MEMCACHED_HOST=127.0.0.1

VITE_APP_NAME="${APP_NAME}"

# -----------------------------------------------------------------------------
# Dev server (phone access) — set by scripts/setup-dev-https.ps1
# -----------------------------------------------------------------------------
DEV_LAN_IP=

# -----------------------------------------------------------------------------
# Frontend (Vite) — must start with VITE_
# Leave VITE_API_URL empty to use dev proxy: https://YOUR_IP:5174/api → API on PC
# Do NOT set VITE_API_URL=http://127.0.0.1:8000/api on phone (breaks on device)
# -----------------------------------------------------------------------------
VITE_API_URL=
VITE_GOOGLE_MAPS_API_KEY=
